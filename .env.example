# ======================================================
# AIOps IoT Monitoring - Environment Variables Template
# Copy this file to .env and fill in values. Never commit .env
# ======================================================

# --- LLM Backend (Primary: Ollama, Fallback: OpenAI) ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional fallback - leave blank to use Ollama only
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Database ---
DATABASE_URL=sqlite:///./aiops_iot.db

# --- Backend API ---
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# --- Auth (Identity-Aware Agents) ---
JWT_SECRET=change-me-in-production-use-secrets-token-urlsafe-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Agent identity tokens (auto-generated on first run if blank)
AGENT_SIGNING_KEY=

# --- Simulator ---
SIM_DEVICE_COUNT=12
SIM_INTERVAL_SECONDS=5
SIM_ANOMALY_RATE=0.08

# --- Dashboard ---
STREAMLIT_API_BASE=http://localhost:8000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
